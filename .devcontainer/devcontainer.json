{
  "name": "Scala Colours",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "scalameta.metals",
        "scala-lang.scala",
        "anthropic.claude-code",
        "Continue.continue",
        "DavidAnson.vscode-markdownlint",
        "github.vscode-github-actions",
        "github.vscode-pull-request-github",
        "mhutchie.git-graph",
        "codezombiech.gitignore",
        "azuretools.vscode-containers"
      ]
    }
  }
}
