{
  "editor": {
    "formatOnSave": true,
    "tabSize": 2,
    "indentSize": 2,
    "insertSpaces": true,
    "detectIndentation": false,
    "stickyScroll": {
      "enabled": false
    },
  },
  // Agents
  "github.copilot.enable": {
    "*": false
  },
  "files.watcherExclude": {
    "**/target": true,
    "**/.bloop": true,
    "**/.metals": true
  },
  "files.insertFinalNewline": true
}
